<form class="{{cssClass}}" autocomplete="off">
  <header class="sheet-header">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" height="100" width="100">
    <div class="header-fields">
      <h1>
        <input name="name" type="text" value="{{actor.name}}" placeholder="{{rolenrollLocalize 'ROLENROLL.Actor.Name'}}">
      </h1>
      <div class="profile-grid">
        <label>
          <span>{{rolenrollLocalize "ROLENROLL.Profile.Level"}}</span>
          <input type="number" name="system.profile.level" value="{{system.profile.level}}" min="0">
        </label>
        <label>
          <span>{{rolenrollLocalize "ROLENROLL.Profile.Exp"}}</span>
          <span class="resource-inputs">
            <input type="number" name="system.profile.exp" value="{{system.profile.exp}}" min="0">
            <span>/</span>
            <input type="number" name="system.profile.expMax" value="{{system.profile.expMax}}" min="0">
          </span>
        </label>
      </div>
      <div class="resource-grid">
        <label>
          <span>{{rolenrollLocalize "ROLENROLL.Resource.Health"}}</span>
          <span class="resource-inputs">
            <input type="number" name="system.resources.health.value" value="{{system.resources.health.value}}">
            <span>/</span>
            <input type="number" name="system.resources.health.max" value="{{system.resources.health.max}}">
          </span>
        </label>
        <label>
          <span>{{rolenrollLocalize "ROLENROLL.Resource.Willpower"}}</span>
          <span class="resource-inputs">
            <input type="number" name="system.resources.willpower.value" value="{{system.resources.willpower.value}}">
            <span>/</span>
            <input type="number" name="system.resources.willpower.max" value="{{system.resources.willpower.max}}">
          </span>
        </label>
        <label>
          <span>{{rolenrollLocalize "ROLENROLL.Resource.Defense"}}</span>
          <input type="number" name="system.defense" value="{{system.defense}}">
        </label>
        <label>
          <span>{{rolenrollLocalize "ROLENROLL.Resource.Mental"}}</span>
          <span class="resource-inputs">
            <input type="number" name="system.resources.mental.value" value="{{system.resources.mental.value}}" min="0">
            <span>/</span>
            <input type="number" name="system.resources.mental.max" value="{{system.resources.mental.max}}" min="1" max="18">
          </span>
        </label>
      </div>
    </div>
  </header>

  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="attributes">{{rolenrollLocalize "ROLENROLL.Tab.Attributes"}}</a>
    <a class="item" data-tab="general">{{rolenrollLocalize "ROLENROLL.Tab.GeneralAbility"}}</a>
    <a class="item" data-tab="extra">{{rolenrollLocalize "ROLENROLL.Tab.ExtraSkill"}}</a>
    <a class="item" data-tab="inventory">{{rolenrollLocalize "ROLENROLL.Tab.Inventory"}}</a>
    <a class="item" data-tab="status">{{rolenrollLocalize "ROLENROLL.Tab.Status"}}</a>
    <a class="item" data-tab="more">{{rolenrollLocalize "ROLENROLL.Tab.More"}}</a>
  </nav>

  <section class="sheet-body">
    <div class="tab" data-group="primary" data-tab="attributes">
      <div class="attribute-grid">
        {{#each attributes}}
          <div class="attribute-row">
            <div class="attribute-name">
              <span>{{label}}</span>
              <small>{{code}}</small>
            </div>
            <input type="hidden" name="system.attributes.{{key}}" value="{{value}}">
            <div class="stat-dots" aria-label="{{label}}">
              {{#each dots}}
                <button
                  type="button"
                  class="stat-dot {{#if active}}active{{/if}}"
                  data-attribute-dot="{{../key}}"
                  data-value="{{value}}"
                  aria-label="{{../label}} {{value}}"
                ></button>
              {{/each}}
            </div>
            <label class="stat-bonus">
              <input type="checkbox" name="system.attributeBonuses.{{key}}" {{#if bonus}}checked{{/if}}>
              <span>{{rolenrollLocalize "ROLENROLL.Roll.AttributeSucceed"}}</span>
            </label>
            <button type="button" data-roll-attribute="{{key}}">{{rolenrollLocalize "ROLENROLL.Action.RollD6"}}</button>
          </div>
        {{/each}}
      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="general">
      <div class="ability-groups">
        {{#each generalAbilityGroups}}
          <section class="ability-group">
            <h2>{{label}}</h2>
            <div class="skill-grid">
              {{#each skills}}
                <div class="skill-row">
                  <div class="skill-name">
                    <span>{{label}}</span>
                    <small>{{tag}}</small>
                  </div>
                  <input type="hidden" name="system.skills.{{key}}" value="{{value}}">
                  <div class="stat-dots" aria-label="{{label}}">
                    {{#each dots}}
                      <button
                        type="button"
                        class="stat-dot {{#if active}}active{{/if}}"
                        data-skill-dot="{{../key}}"
                        data-value="{{value}}"
                        aria-label="{{../label}} {{value}}"
                      ></button>
                    {{/each}}
                  </div>
                  <label class="stat-bonus">
                    <input type="checkbox" name="system.skillBonuses.{{key}}" {{#if bonus}}checked{{/if}}>
                    <span>{{rolenrollLocalize "ROLENROLL.Roll.AttributeSucceed"}}</span>
                  </label>
                  <button type="button" data-roll-skill="{{key}}">{{rolenrollLocalize "ROLENROLL.Action.RollD6"}}</button>
                </div>
              {{/each}}
            </div>
          </section>
        {{/each}}
      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="extra">
      <div class="extra-skill-toolbar">
        <button type="button" data-add-extra-skill>{{rolenrollLocalize "ROLENROLL.ExtraSkill.Add"}}</button>
      </div>

      <div class="extra-skill-grid">
        {{#each extraSkillSlots}}
          <article class="compact-card extra-skill-card" data-extra-skill-row="{{slot}}">
            <div class="compact-card-main">
              <strong>{{#if name}}{{name}}{{else}}{{rolenrollLocalize "ROLENROLL.ExtraSkill.Name"}}{{/if}}</strong>
              <div class="compact-card-meta">
                <span>{{points}} {{rolenrollLocalize "ROLENROLL.Roll.TotalDice"}}</span>
                {{#if bonus}}<span>{{rolenrollLocalize "ROLENROLL.Roll.AttributeSucceed"}}</span>{{/if}}
                {{#each dependencyLabels}}<span>{{this}}</span>{{/each}}
              </div>
              {{#if details}}<p>{{details}}</p>{{/if}}
            </div>
            <div class="compact-card-actions">
              <button type="button" data-roll-extra-skill="{{slot}}">{{rolenrollLocalize "ROLENROLL.Action.RollD6"}}</button>
              <button type="button" data-edit-extra-skill="{{slot}}">{{rolenrollLocalize "ROLENROLL.Action.Edit"}}</button>
              <button type="button" data-remove-extra-skill="{{slot}}">{{rolenrollLocalize "ROLENROLL.Action.Remove"}}</button>
            </div>
          </article>
        {{else}}
          <p class="empty-list">{{rolenrollLocalize "ROLENROLL.ExtraSkill.Empty"}}</p>
        {{/each}}
      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="inventory">
      <div class="inventory-layout">
        <section class="inventory-panel">
          <div class="inventory-panel-header">
            <h2>{{rolenrollLocalize "ROLENROLL.Inventory.Equipment"}}</h2>
            <button type="button" data-add-equipment>{{rolenrollLocalize "ROLENROLL.Inventory.AddGear"}}</button>
          </div>

          <div class="inventory-entry-list">
            {{#each equipmentSlots}}
              <article class="compact-card" data-equipment-entry="{{slot}}">
                <div class="compact-card-main">
                  <strong>{{#if name}}{{name}}{{else}}{{rolenrollLocalize "ROLENROLL.Inventory.GearName"}}{{/if}}</strong>
                  <div class="compact-card-meta">
                    <span>{{locationLabel}}</span>
                    {{#if damage}}<span>{{rolenrollLocalize "ROLENROLL.Inventory.Damage"}} {{damage}}</span>{{/if}}
                    {{#if charge}}<span>{{rolenrollLocalize "ROLENROLL.Inventory.Charge"}} {{charge}}</span>{{/if}}
                    {{#if defense}}<span>{{rolenrollLocalize "ROLENROLL.Inventory.Defense"}} {{defense}}</span>{{/if}}
                    {{#if toughness}}<span>{{rolenrollLocalize "ROLENROLL.Inventory.Toughness"}} {{toughness}}</span>{{/if}}
                  </div>
                  {{#if details}}<p>{{details}}</p>{{/if}}
                </div>
                <div class="compact-card-actions">
                  <button type="button" data-edit-equipment="{{slot}}">{{rolenrollLocalize "ROLENROLL.Action.Edit"}}</button>
                  <button type="button" data-remove-equipment="{{slot}}">{{rolenrollLocalize "ROLENROLL.Action.Remove"}}</button>
                </div>
              </article>
            {{else}}
              <p class="empty-list">{{rolenrollLocalize "ROLENROLL.Inventory.NoEquipment"}}</p>
            {{/each}}
          </div>
        </section>

        <section class="inventory-panel">
          <div class="inventory-panel-header">
            <h2>{{rolenrollLocalize "ROLENROLL.Inventory.Items"}}</h2>
            <button type="button" data-add-inventory-item>{{rolenrollLocalize "ROLENROLL.Inventory.AddItem"}}</button>
          </div>

          <div class="inventory-entry-list">
            {{#each inventoryItems}}
              <article class="compact-card item-card" data-inventory-item="{{slot}}">
                <div class="compact-card-main">
                  <strong>{{#if name}}{{name}}{{else}}{{rolenrollLocalize "ROLENROLL.Inventory.ItemName"}}{{/if}}</strong>
                  <div class="compact-card-meta">
                    <span>{{rolenrollLocalize "ROLENROLL.Inventory.Quantity"}} {{quantity}}</span>
                  </div>
                  {{#if details}}<p>{{details}}</p>{{/if}}
                </div>
                <div class="compact-card-actions">
                  <button type="button" data-use-inventory-item="{{slot}}">{{rolenrollLocalize "ROLENROLL.Inventory.Use"}}</button>
                  <button type="button" data-edit-inventory-item="{{slot}}">{{rolenrollLocalize "ROLENROLL.Action.Edit"}}</button>
                  <button type="button" data-remove-inventory-item="{{slot}}">{{rolenrollLocalize "ROLENROLL.Action.Remove"}}</button>
                </div>
              </article>
            {{else}}
              <p class="empty-list">{{rolenrollLocalize "ROLENROLL.Inventory.NoItems"}}</p>
            {{/each}}
          </div>
        </section>
      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="status">
      <div class="status-toolbar">
        <button type="button" data-add-status>{{rolenrollLocalize "ROLENROLL.Status.Add"}}</button>
      </div>

      <div class="status-layout">
        <section class="status-column">
          <h2>{{rolenrollLocalize "ROLENROLL.Status.Buffs"}}</h2>
          <div class="status-entry-list">
            {{#each statusBuffs}}
              <article class="compact-card status-entry-buff" data-status-entry="{{slot}}">
                <div class="compact-card-main">
                  <strong>{{#if name}}{{name}}{{else}}{{rolenrollLocalize "ROLENROLL.Status.Untitled"}}{{/if}}</strong>
                  <div class="compact-card-meta">
                    <span>{{categoryLabel}}</span>
                    <span>{{durationText}}</span>
                  </div>
                  {{#if details}}<p>{{details}}</p>{{/if}}
                </div>
                <div class="compact-card-actions">
                  <button type="button" data-edit-status="{{slot}}">{{rolenrollLocalize "ROLENROLL.Action.Edit"}}</button>
                  <button type="button" data-remove-status="{{slot}}">{{rolenrollLocalize "ROLENROLL.Action.Remove"}}</button>
                </div>
              </article>
            {{else}}
              <p class="empty-list">{{rolenrollLocalize "ROLENROLL.Status.NoBuffs"}}</p>
            {{/each}}
          </div>
        </section>

        <section class="status-column">
          <h2>{{rolenrollLocalize "ROLENROLL.Status.Debuffs"}}</h2>
          <div class="status-entry-list">
            {{#each statusDebuffs}}
              <article class="compact-card status-entry-debuff" data-status-entry="{{slot}}">
                <div class="compact-card-main">
                  <strong>{{#if name}}{{name}}{{else}}{{rolenrollLocalize "ROLENROLL.Status.Untitled"}}{{/if}}</strong>
                  <div class="compact-card-meta">
                    <span>{{categoryLabel}}</span>
                    <span>{{durationText}}</span>
                  </div>
                  {{#if details}}<p>{{details}}</p>{{/if}}
                </div>
                <div class="compact-card-actions">
                  <button type="button" data-edit-status="{{slot}}">{{rolenrollLocalize "ROLENROLL.Action.Edit"}}</button>
                  <button type="button" data-remove-status="{{slot}}">{{rolenrollLocalize "ROLENROLL.Action.Remove"}}</button>
                </div>
              </article>
            {{else}}
              <p class="empty-list">{{rolenrollLocalize "ROLENROLL.Status.NoDebuffs"}}</p>
            {{/each}}
          </div>
        </section>
      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="more">
      <section class="more-profile">
        <label>
          <span>{{rolenrollLocalize "ROLENROLL.Profile.Gender"}}</span>
          <input type="text" name="system.profile.gender" value="{{system.profile.gender}}">
        </label>
        <label>
          <span>{{rolenrollLocalize "ROLENROLL.Profile.Age"}}</span>
          <input type="text" name="system.profile.age" value="{{system.profile.age}}">
        </label>
        <label>
          <span>{{rolenrollLocalize "ROLENROLL.Profile.Race"}}</span>
          <input type="text" name="system.profile.race" value="{{system.profile.race}}">
        </label>
        <label>
          <span>{{rolenrollLocalize "ROLENROLL.Profile.WillSource"}}</span>
          <input type="text" name="system.profile.willSource" value="{{system.profile.willSource}}">
        </label>
        <label class="more-profile-background">
          <span>{{rolenrollLocalize "ROLENROLL.Profile.Background"}}</span>
          <textarea name="system.profile.background">{{system.profile.background}}</textarea>
        </label>
      </section>
    </div>
  </section>
</form>
