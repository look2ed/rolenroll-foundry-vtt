<form class="{{cssClass}}" autocomplete="off">
  <header class="sheet-header">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" height="100" width="100">
    <div class="header-fields">
      <h1>
        <input name="name" type="text" value="{{actor.name}}" placeholder="{{localize 'ROLENROLL.Actor.Name'}}">
      </h1>
      <div class="profile-grid">
        <label>
          <span>{{localize "ROLENROLL.Profile.Level"}}</span>
          <input type="number" name="system.profile.level" value="{{system.profile.level}}" min="0">
        </label>
        <label>
          <span>{{localize "ROLENROLL.Profile.Exp"}}</span>
          <span class="resource-inputs">
            <input type="number" name="system.profile.exp" value="{{system.profile.exp}}" min="0">
            <span>/</span>
            <input type="number" name="system.profile.expMax" value="{{system.profile.expMax}}" min="0">
          </span>
        </label>
      </div>
      <div class="resource-grid">
        <label>
          <span>{{localize "ROLENROLL.Resource.Health"}}</span>
          <span class="resource-inputs">
            <input type="number" name="system.resources.health.value" value="{{system.resources.health.value}}">
            <span>/</span>
            <input type="number" name="system.resources.health.max" value="{{system.resources.health.max}}">
          </span>
        </label>
        <label>
          <span>{{localize "ROLENROLL.Resource.Willpower"}}</span>
          <span class="resource-inputs">
            <input type="number" name="system.resources.willpower.value" value="{{system.resources.willpower.value}}">
            <span>/</span>
            <input type="number" name="system.resources.willpower.max" value="{{system.resources.willpower.max}}">
          </span>
        </label>
        <label>
          <span>{{localize "ROLENROLL.Resource.Defense"}}</span>
          <input type="number" name="system.defense" value="{{system.defense}}">
        </label>
        <label>
          <span>{{localize "ROLENROLL.Resource.Mental"}}</span>
          <span class="resource-inputs">
            <input type="number" name="system.resources.mental.value" value="{{system.resources.mental.value}}" min="0">
            <span>/</span>
            <input type="number" name="system.resources.mental.max" value="{{system.resources.mental.max}}" min="1" max="18">
          </span>
        </label>
      </div>
    </div>
  </header>

  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="attributes">{{localize "ROLENROLL.Tab.Attributes"}}</a>
    <a class="item" data-tab="general">{{localize "ROLENROLL.Tab.GeneralAbility"}}</a>
    <a class="item" data-tab="extra">{{localize "ROLENROLL.Tab.ExtraSkill"}}</a>
    <a class="item" data-tab="inventory">{{localize "ROLENROLL.Tab.Inventory"}}</a>
    <a class="item" data-tab="notes">{{localize "ROLENROLL.Tab.Notes"}}</a>
  </nav>

  <section class="sheet-body">
    <div class="tab" data-group="primary" data-tab="attributes">
      <section class="roll-controls">
        <div class="special-dice-builder">
          <div class="special-dice-builder-header">
            <span>{{localize "ROLENROLL.Roll.SpecialDice"}}</span>
            <button type="button" data-add-special-die>{{localize "ROLENROLL.Roll.AddSpecialDie"}}</button>
          </div>
          <input type="hidden" name="system.roll.specialDice" value="{{system.roll.specialDice}}">
          <div class="special-dice-list">
            {{#each specialDice}}
              <div class="special-die-card">
                <div class="special-die-card-faces" aria-label="{{localize 'ROLENROLL.Roll.SpecialDie'}}">
                  {{#each faces}}
                    <button
                      type="button"
                      class="special-die-face {{className}}"
                      data-special-die-face="{{../dieIndex}}:{{faceIndex}}"
                      {{#if locked}}disabled{{/if}}
                    >{{display}}</button>
                  {{/each}}
                </div>
                <button type="button" data-remove-special-die="{{dieIndex}}">{{localize "ROLENROLL.Action.Remove"}}</button>
              </div>
            {{else}}
              <p class="special-dice-empty">{{localize "ROLENROLL.Roll.NoSpecialDice"}}</p>
            {{/each}}
          </div>
        </div>
        <label>
          <span>{{localize "ROLENROLL.Roll.Succeed"}}</span>
          <input type="number" name="system.roll.success" value="{{system.roll.success}}" min="0">
        </label>
        <label>
          <span>{{localize "ROLENROLL.Roll.Penalty"}}</span>
          <input type="number" name="system.roll.penalty" value="{{system.roll.penalty}}" min="0">
        </label>
      </section>

      <div class="attribute-grid">
        {{#each attributes}}
          <div class="attribute-row">
            <div class="attribute-name">
              <span>{{label}}</span>
              <small>{{code}}</small>
            </div>
            <input type="hidden" name="system.attributes.{{key}}" value="{{value}}">
            <div class="stat-dots" aria-label="{{label}}">
              {{#each dots}}
                <button
                  type="button"
                  class="stat-dot {{#if active}}active{{/if}}"
                  data-attribute-dot="{{../key}}"
                  data-value="{{value}}"
                  aria-label="{{../label}} {{value}}"
                ></button>
              {{/each}}
            </div>
            <label class="stat-bonus">
              <input type="checkbox" name="system.attributeBonuses.{{key}}" {{#if bonus}}checked{{/if}}>
              <span>{{localize "ROLENROLL.Roll.AttributeSucceed"}}</span>
            </label>
            <button type="button" data-roll-attribute="{{key}}">{{localize "ROLENROLL.Action.RollD6"}}</button>
          </div>
        {{/each}}
      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="general">
      <div class="ability-groups">
        {{#each generalAbilityGroups}}
          <section class="ability-group">
            <h2>{{label}}</h2>
            <div class="skill-grid">
              {{#each skills}}
                <div class="skill-row">
                  <div class="skill-name">
                    <span>{{label}}</span>
                    <small>{{tag}}</small>
                  </div>
                  <input type="hidden" name="system.skills.{{key}}" value="{{value}}">
                  <div class="stat-dots" aria-label="{{label}}">
                    {{#each dots}}
                      <button
                        type="button"
                        class="stat-dot {{#if active}}active{{/if}}"
                        data-skill-dot="{{../key}}"
                        data-value="{{value}}"
                        aria-label="{{../label}} {{value}}"
                      ></button>
                    {{/each}}
                  </div>
                  <label class="stat-bonus">
                    <input type="checkbox" name="system.skillBonuses.{{key}}" {{#if bonus}}checked{{/if}}>
                    <span>{{localize "ROLENROLL.Roll.AttributeSucceed"}}</span>
                  </label>
                  <button type="button" data-roll-skill="{{key}}">{{localize "ROLENROLL.Action.RollD6"}}</button>
                </div>
              {{/each}}
            </div>
          </section>
        {{/each}}
      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="extra">
      <div class="extra-skill-toolbar">
        <button type="button" data-add-extra-skill>{{localize "ROLENROLL.ExtraSkill.Add"}}</button>
      </div>

      <div class="extra-skill-grid">
        {{#each extraSkillSlots}}
          <section class="extra-skill-row" data-extra-skill-row="{{slot}}">
            <label class="extra-skill-name">
              <span>{{localize "ROLENROLL.ExtraSkill.Name"}}</span>
              <input type="text" name="system.extraSkills.{{slot}}.name" value="{{name}}">
            </label>
            <input type="hidden" name="system.extraSkills.{{slot}}.points" value="{{points}}">
            <input type="hidden" name="system.extraSkills.{{slot}}.active" value="true">
            <input type="hidden" name="system.extraSkills.{{slot}}.dependencies" value="{{dependencies}}">

            <div class="extra-skill-dependencies">
              <span>{{localize "ROLENROLL.ExtraSkill.LinkedStats"}}</span>
              <div class="dependency-grid">
                {{#each dependencyOptions}}
                  <label class="dependency-option">
                    <input
                      type="checkbox"
                      value="{{key}}"
                      data-extra-skill-dependency="{{../slot}}"
                      {{#if checked}}checked{{/if}}
                    >
                    <span>{{label}}</span>
                  </label>
                {{/each}}
              </div>
            </div>

            <div class="stat-dots extra-skill-dots" aria-label="{{name}}">
              {{#each dots}}
                <button
                  type="button"
                  class="stat-dot {{#if active}}active{{/if}}"
                  data-extra-skill-dot="{{../slot}}"
                  data-value="{{value}}"
                  aria-label="{{../name}} {{value}}"
                ></button>
              {{/each}}
            </div>
            <label class="stat-bonus">
              <input type="checkbox" name="system.extraSkills.{{slot}}.bonus" {{#if bonus}}checked{{/if}}>
              <span>{{localize "ROLENROLL.Roll.AttributeSucceed"}}</span>
            </label>
            <label class="extra-skill-details">
              <span>{{localize "ROLENROLL.ExtraSkill.Details"}}</span>
              <textarea name="system.extraSkills.{{slot}}.details">{{details}}</textarea>
            </label>
            <div class="extra-skill-actions">
              <button type="button" data-roll-extra-skill="{{slot}}">{{localize "ROLENROLL.Action.RollD6"}}</button>
              <button type="button" data-remove-extra-skill="{{slot}}">{{localize "ROLENROLL.Action.Remove"}}</button>
            </div>
          </section>
        {{else}}
          <p class="empty-list">{{localize "ROLENROLL.ExtraSkill.Empty"}}</p>
        {{/each}}
      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="inventory">
      <div class="inventory-layout">
        <section class="inventory-panel">
          <div class="inventory-panel-header">
            <h2>{{localize "ROLENROLL.Inventory.Equipment"}}</h2>
            <button type="button" data-add-equipment>{{localize "ROLENROLL.Inventory.AddGear"}}</button>
          </div>

          <div class="inventory-entry-list">
            {{#each equipmentSlots}}
              <article class="inventory-entry" data-equipment-entry="{{slot}}">
                <input type="hidden" name="system.equipmentEntries.{{slot}}.active" value="true">
                <label class="inventory-entry-name">
                  <span>{{localize "ROLENROLL.Inventory.GearName"}}</span>
                  <input type="text" name="system.equipmentEntries.{{slot}}.name" value="{{name}}">
                </label>
                <label>
                  <span>{{localize "ROLENROLL.Inventory.Location"}}</span>
                  <select name="system.equipmentEntries.{{slot}}.location">
                    {{#each locationOptions}}
                      <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                    {{/each}}
                  </select>
                </label>
                <label class="inventory-entry-details">
                  <span>{{localize "ROLENROLL.Inventory.Details"}}</span>
                  <textarea name="system.equipmentEntries.{{slot}}.details">{{details}}</textarea>
                </label>
                <div class="inventory-entry-actions">
                  <button type="button" data-remove-equipment="{{slot}}">{{localize "ROLENROLL.Action.Remove"}}</button>
                </div>
              </article>
            {{else}}
              <p class="empty-list">{{localize "ROLENROLL.Inventory.NoEquipment"}}</p>
            {{/each}}
          </div>
        </section>

        <section class="inventory-panel">
          <div class="inventory-panel-header">
            <h2>{{localize "ROLENROLL.Inventory.Items"}}</h2>
            <button type="button" data-add-inventory-item>{{localize "ROLENROLL.Inventory.AddItem"}}</button>
          </div>

          <div class="inventory-entry-list">
            {{#each inventoryItems}}
              <article class="inventory-entry" data-inventory-item="{{slot}}">
                <input type="hidden" name="system.inventoryItems.{{slot}}.active" value="true">
                <label class="inventory-entry-name">
                  <span>{{localize "ROLENROLL.Inventory.ItemName"}}</span>
                  <input type="text" name="system.inventoryItems.{{slot}}.name" value="{{name}}">
                </label>
                <label class="inventory-entry-quantity">
                  <span>{{localize "ROLENROLL.Inventory.Quantity"}}</span>
                  <input type="number" name="system.inventoryItems.{{slot}}.quantity" value="{{quantity}}" min="0">
                </label>
                <label class="inventory-entry-details">
                  <span>{{localize "ROLENROLL.Inventory.Details"}}</span>
                  <textarea name="system.inventoryItems.{{slot}}.details">{{details}}</textarea>
                </label>
                <div class="inventory-entry-actions">
                  <button type="button" data-use-inventory-item="{{slot}}">{{localize "ROLENROLL.Inventory.Use"}}</button>
                  <button type="button" data-remove-inventory-item="{{slot}}">{{localize "ROLENROLL.Action.Remove"}}</button>
                </div>
              </article>
            {{else}}
              <p class="empty-list">{{localize "ROLENROLL.Inventory.NoItems"}}</p>
            {{/each}}
          </div>
        </section>
      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="notes">
      {{editor system.notes target="system.notes" button=true owner=owner editable=editable}}
    </div>
  </section>
</form>
